# =====================================================
#  متجر الصقر — متغيّرات بيئة الخادم (Express + Postgres)
# =====================================================

# --- قاعدة البيانات -----------------------------------
# للتطوير المحلي: استخدم رابط بروكسي Railway العام
#   DATABASE_URL=postgresql://postgres:PASSWORD@shinkansen.proxy.rlwy.net:PORT/railway
#
# للإنتاج داخل Railway: استخدم الرابط الداخلي (الأسرع والأكثر أمانًا)
#   DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway
#   أو الأفضل على Railway: اربط الخدمة بـ Postgres واستخدم المرجع:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/saqer

# SSL يُكتشف تلقائيًا (داخلي→معطّل، عام→مُفعّل). يمكن الإجبار هنا:
# PG_SSL=true|false
PG_SSL=

# --- الخادم -------------------------------------------
PORT=3001
# عدة أصول مفصولة بفاصلة. في الإنتاج ضع رابط موقع Netlify فقط.
# مثال: CORS_ORIGIN=https://your-site.netlify.app
# اتركه فارغًا في التطوير للسماح بأي أصل.
CORS_ORIGIN=http://localhost:5173

# --- بيانات دخول المشرف -------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- سرّ توقيع JWT (نص عشوائي طويل في الإنتاج) --------
JWT_SECRET=replace-with-a-long-random-string

# --- رفع الصور ----------------------------------------
UPLOAD_DIR=uploads
UPLOAD_MAX_MB=6

# انسخ هذا الملف إلى .env واملأ القيم

# Postgres (Railway يعطيك DATABASE_URL من تبويب Variables)
DATABASE_URL=postgresql://user:password@host:5432/saqer
PG_SSL=false

# الخادم
PORT=3001
# عدة عناوين مفصولة بفاصلة؛ لاختبار الهاتف على Wi‑Fi أضف مثلاً http://192.168.1.10:5173
# إن تركتها فارغة يقبل الخادم أي أصل في التطوير (لا تستخدم ذلك في الإنتاج).
CORS_ORIGIN=http://localhost:5173

# بيانات دخول المشرف
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# سرّ توقيع JWT — يجب أن يكون نصاً طويلاً عشوائياً في الإنتاج
JWT_SECRET=replace-with-a-long-random-string

# رفع الصور
UPLOAD_DIR=uploads
UPLOAD_MAX_MB=6
